<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0A2540">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>

  <body>
    {% section 'header' %}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    <footer class="container">
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px;">
        <div>
          <h3 style="color: var(--color-primary);">About Kotacart</h3>
          <p>India's leading marketplace for verified, high-quality pre-owned JEE, NEET, and Foundation study materials.</p>
        </div>
        <div>
          <h3 style="color: var(--color-primary);">Quick Links</h3>
          <a href="/pages/shipping-policy" style="display: block; margin-bottom: 5px;">Shipping Policy</a>
          <a href="/pages/return-policy" style="display: block; margin-bottom: 5px;">Return Policy</a>
          <a href="/pages/contact" style="display: block; margin-bottom: 5px;">Contact Us</a>
        </div>
        <div>
          <h3 style="color: var(--color-primary);">Follow Us</h3>
          <p>Join our community of toppers on Telegram and WhatsApp.</p>
        </div>
      </div>
      <div style="border-top: 1px solid #EEE; margin-top: 40px; padding-top: 20px; text-align: center; color: #999;">
        &copy; {{ 'now' | date: "%Y" }}, Kotacart.com. Powered by Shopify.
      </div>
    </footer>
  </body>
</html>
