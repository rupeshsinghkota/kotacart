<div class="featured-collection-v3 container">
  <div class="collection-header-v3">
    <h2 class="collection-title-v3">{{ section.settings.title | default: "Trending Modules" }}</h2>
    {% if section.settings.show_view_all and section.settings.collection != blank %}
      <a href="{{ collections[section.settings.collection].url }}" class="collection-view-all">
        See All <span aria-hidden="true">&rarr;</span>
      </a>
    {% endif %}
  </div>
  
  <div class="products-scroller">
    {% assign count = 0 %}
    {% if section.settings.collection != blank and collections[section.settings.collection].products_count > 0 %}
      {% for product in collections[section.settings.collection].products limit: section.settings.limit %}
        <div class="product-scroller-item">
          {% render 'product-card', product: product %}
        </div>
        {% assign count = count | plus: 1 %}
      {% endfor %}
    {% endif %}

    {% if count == 0 %}
      {% for i in (1..section.settings.limit) %}
        <div class="product-scroller-item">
          <div class="pw-card">
            <div class="pw-card-placeholder" style="height: 250px; background: #f8f9fa; display:flex; align-items:center; justify-content:center; color:#999; font-size:12px;">Link Collection</div>
            <div class="pw-card-info">
              <h3 class="pw-card-title">Setup Required</h3>
              <div class="pw-price-row">
                <span class="pw-current-price">₹0</span>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</div>

<style>
  .featured-collection-v3 {
    margin: 40px auto;
  }

  /* Section Header */
  .collection-header-v3 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding: 0 10px; /* Align with scrolled items */
  }

  .collection-title-v3 {
    font-size: 24px;
    font-weight: 800;
    color: #111827;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .collection-view-all {
    color: var(--brand-purple, #5b4df3);
    text-decoration: none;
    font-weight: 700;
    font-size: 16px;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: opacity 0.2s;
  }

  .collection-view-all:hover {
    opacity: 0.8;
  }

  /* Horizontal Scroller */
  .products-scroller {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    padding: 10px 10px 20px 10px; /* Added bottom padding to make room for scrollbar */
    margin: -10px; /* Offset padding */
    scroll-snap-type: x mandatory;
    scroll-padding-left: 10px;
    /* Removed scrollbar-width: none to allow Firefox scrollbar */
  }

  /* Custom Scrollbar for visual cue */
  .products-scroller::-webkit-scrollbar {
    height: 6px; /* Thin, elegant scrollbar */
  }

  .products-scroller::-webkit-scrollbar-track {
    background: #f1f5f9; 
    border-radius: 10px;
    margin: 0 10px; /* Pad the track slightly */
  }

  .products-scroller::-webkit-scrollbar-thumb {
    background: #cbd5e1; 
    border-radius: 10px;
  }

  .products-scroller::-webkit-scrollbar-thumb:hover {
    background: #94a3b8; 
  }

  .product-scroller-item {
    flex: 0 0 calc(20% - 16px); /* 5 columns on desktop */
    scroll-snap-align: start;
    min-width: 230px; /* Squeezed width to match exactly the PW layout */
  }

  @media (max-width: 1200px) {
    .product-scroller-item {
      flex: 0 0 calc(25% - 15px); /* 4 columns */
    }
  }

  @media (max-width: 900px) {
    .product-scroller-item {
      flex: 0 0 calc(33.333% - 13.33px); /* 3 columns */
    }
  }

  @media (max-width: 768px) {
    .featured-collection-v3 {
      margin: 20px auto;
    }
    .products-scroller {
      gap: 16px;
    }
    .product-scroller-item {
      flex: 0 0 250px; /* Fixed width for horizontal scrolling on mobile */
    }
    .collection-header-v3 {
       padding: 0 5px;
       margin-bottom: 16px;
    }
    .collection-title-v3 {
       font-size: 20px;
    }
    .collection-view-all {
       font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Popular NEET Books"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'See All' link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
