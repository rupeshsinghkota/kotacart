      justify-content: flex-start;
    }
    .category-nav ul {
      padding: 10px 20px;
    }
    .category-nav a {
      font-size: 13px;
      background: #f0f0ff;
      padding: 8px 16px;
      border-radius: 25px;
      border: 1px solid #e0e0ff;
    }
    .has-dropdown .mega-menu {
      display: none !important; 
    }
  }


  .category-nav a {
    text-decoration: none;
    color: #444;
    font-size: 14px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: color 0.3s;
  }
  .category-nav a:hover {
    color: var(--brand-purple);
  }
  /* Dropdown / Mega Menu */
  .has-dropdown {
    position: relative;
  }

  .has-dropdown:hover .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    background: white;
    width: 600px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    border-radius: 16px;
    padding: 30px;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(15px);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2000;
    border: 1px solid #ebebeb;
    /* Add an invisible bridging gap to prevent hover loss */
  }

  /* Invisible hover bridge */
  .mega-menu::before {
    content: '';
    position: absolute;
    top: -20px;
    left: 0;
    right: 0;
    height: 20px;
  }

  .mega-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }

  .mega-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 14px !important;
    text-transform: uppercase !important;
    color: #888 !important;
    letter-spacing: 1px !important;
    font-weight: 700 !important;
    margin-bottom: 15px !important;
    border-bottom: 1px solid #f0f0f0;
    padding-bottom: 8px;
  }

  .arrow-right {
    color: #999;
    font-size: 14px;
    transition: transform 0.2s;
  }

  .mega-head:hover .arrow-right {
    transform: translateX(5px);
    color: var(--brand-purple);
