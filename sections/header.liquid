    background: #fff;
    padding: 8px 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .category-nav-container {
    display: flex;
    align-items: center;
    justify-content: center; /* Center correctly on desktop */
  }

  .category-nav ul {
    list-style: none;
    display: flex;
    gap: 25px;
    margin: 0;
    padding: 0;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .header-bottom-row {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      justify-content: flex-start;
    }
