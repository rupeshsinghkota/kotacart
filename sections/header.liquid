    align-items: center;
    gap: 15px;
    padding: 15px 20px;
    color: #333;
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
  }

  .mobile-nav-link svg {
    width: 20px; height: 20px; color: #666;
  }

  .mobile-nav-divider {
    height: 1px;
    background: #f0f0f0;
    margin: 10px 20px;
  }

  .mobile-nav-footer {
