    font-weight: 700;
    font-size: 15px;
    text-align: center;
    transition: background 0.2s;
  }

  .mobile-wa-icon {
    display: none; /* Overridden below on mobile */
  }

  @media (max-width: 768px) {
    .header-grid {
      display: grid;
      grid-template-columns: auto 1fr auto; /* Original Left-Aligned: Hamburger | Logo (Expands) | Icons */
      grid-template-rows: auto auto; 
      gap: 15px;
      padding: 5px 10px;
    }
    .mobile-menu-toggle {
      display: block;
      grid-row: 1;
      grid-column: 1;
    }
    .header-logo-container {
      grid-row: 1;
      grid-column: 2;
    }
    .header-utility-container {
      grid-row: 1;
      grid-column: 3;
      gap: 15px;
    }
    
    .header-utility-container #nav-cart-desktop,
    .header-utility-container #nav-login-desktop {
      display: none !important;
    }

    .header-utility-container .utility-item span {
