    top: 0;
    left: 0;
    width: 100%;
    z-index: 2000;
    background: white;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    padding: 10px 0; /* Compact mode when fixed */
  }


  .announcement-bar-v3 {
    background: #2e1d82; /* Deep PW Purple */
    color: white;
    padding: 8px 0;
    font-size: 13px;
    font-weight: 500;
    text-align: center;
  }

  .announcement-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .announcement-meta {
    opacity: 0.8;
    font-weight: 400;
  }







  .header-top-row {
    padding: 15px 0;
    background: white;
    border-bottom: 1px solid #ebebeb;
    transition: padding 0.3s ease;
  }

  .header-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
  }

  .header-search-container {
    flex-grow: 1;
    max-width: 600px;
  }

  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
    color: #111827;
  }

  /* --- Mobile Drawer Styles --- */
  .mobile-nav-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.5);
    z-index: 2999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }
  .mobile-nav-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-drawer {
    position: fixed;
    top: 0; left: -300px; bottom: 0;
    width: 280px;
    background: white;
    z-index: 3000;
    box-shadow: 5px 0 15px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .mobile-nav-drawer.is-open {
    transform: translateX(300px);
  }

  .mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border-bottom: 1px solid #eee;
  }

  .mobile-nav-close {
    background: none; border: none; font-size: 24px; cursor: pointer; color: #666;
  }

  .mobile-nav-body {
    padding: 20px 0;
    overflow-y: auto;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 20px;
    color: #333;
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
  }

  .mobile-nav-link svg {
    width: 20px; height: 20px; color: #666;
  }

  .mobile-nav-divider {
    height: 1px;
    background: #f0f0f0;
    margin: 10px 20px;
  }


  @media (max-width: 768px) {
    .header-grid {
      display: grid;
      grid-template-columns: auto 1fr auto; /* Hamburger | Logo | Utility */
      grid-template-rows: auto auto; /* Row 1: Logo/Icons, Row 2: Search */
      gap: 15px;
      padding: 5px 10px;
    }
    .mobile-menu-toggle {
      display: block;
      grid-row: 1;
      grid-column: 1;
    }
    .header-logo-container {
      grid-row: 1;
      grid-column: 2;
    }
    .header-utility-container {
      grid-row: 1;
      grid-column: 3;
      gap: 15px;
    }
    .header-search-container {
      grid-row: 2;
      grid-column: 1 / -1; /* Stretch across entire bottom */
      width: 100%;
      max-width: 100%;
    }
    
    .utility-item span {
      display: none;
    }
    .btn-login-v3 {
      display: none; /* Usually hidden on mobile in PW, kept cleaner */
    }
    
    /* Hide the horizontal scrolling bottom nav on mobile */
    .desktop-only-nav {
      display: none !important;
    }
  }

  /* Logo */
  .brand-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #1a1a1a;
  }
  @media (max-width: 480px) {
    .brand-text { font-size: 16px; }
    .store-label { display: none; }
  }

  .logo-circ {
    background: #000;
    color: white;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 18px;
  }
  .brand-text {
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.5px;
  }
  .store-label {
    font-weight: 400;
    color: #666;
    font-size: 16px;
    margin-left: 5px;
  }

  /* Search Bar - Center */
  .search-form-v3 {
    position: relative;
    width: 100%;
    margin: 0 auto;
  }
  .search-form-v3 input {
    width: 100%;
    padding: 12px 20px;
    padding-right: 50px;
    border: 1px solid #5b4df3; /* PW Purple Solid Border */
    border-radius: 6px;
    font-size: 15px;
    outline: none;
    transition: box-shadow 0.3s;
  }
  .search-form-v3 input:focus {
    box-shadow: 0 0 0 2px rgba(91, 77, 243, 0.2);
  }
  .search-form-v3 button {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: #333;
  }

  /* Utility Icons */
  .header-utility-container {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 30px;
  }
  .utility-item {
    text-decoration: none;
    color: #111827; /* Darker, crisper text */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 600;
    transition: color 0.3s;
  }
  .utility-item:hover {
    color: var(--brand-purple);
  }
  .utility-icon {
    height: 24px;
    display: flex;
    align-items: center;
  }
  .btn-login-v3 {
    background: #5b4df3; /* PW Purple Solid */
