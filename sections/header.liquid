<script>
  // Product page inline search (Kotacart style)
  function openProductSearch() {
    const header = document.getElementById('PmHeaderDefault');
    const searchBar = document.getElementById('PmSearchBar');
    if (header && searchBar) {
      header.style.display = 'none';
      searchBar.style.display = 'flex';
      document.getElementById('PmSearchInput').focus();
    }
  }
  function closeProductSearch() {
    const header = document.getElementById('PmHeaderDefault');
    const searchBar = document.getElementById('PmSearchBar');
    if (header && searchBar) {
      searchBar.style.display = 'none';
      header.style.display = 'flex';
    }
  }

  // Placeholder for any non-sticky scripts
  document.addEventListener('DOMContentLoaded', function() {
    // Mobile Menu Logic
    const mobileToggle = document.getElementById('MobileMenuToggle');
    const mobileDrawer = document.getElementById('MobileNavDrawer');
    const mobileClose = document.getElementById('MobileNavClose');
    const mobileOverlay = document.getElementById('MobileNavOverlay');

    function openMobileMenu() {
      if(mobileDrawer) mobileDrawer.classList.add('is-open');
      if(mobileOverlay) mobileOverlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileMenu() {
      if(mobileDrawer) mobileDrawer.classList.remove('is-open');
      if(mobileOverlay) mobileOverlay.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    if (mobileToggle) mobileToggle.addEventListener('click', openMobileMenu);
    if (mobileClose) mobileClose.addEventListener('click', closeMobileMenu);
    if (mobileOverlay) mobileOverlay.addEventListener('click', closeMobileMenu);

    // Nav Scroll functionality
    const navScrollRight = document.getElementById('NavScrollRight');
    const categoryNavList = document.querySelector('.category-nav ul');
    if (navScrollRight && categoryNavList) {
      navScrollRight.addEventListener('click', () => {
        categoryNavList.scrollBy({ left: 200, behavior: 'smooth' });
      });
    }
  });
</script>

