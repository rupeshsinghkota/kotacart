<div class="pw-card">
  <!-- Image Section -->
  <div class="pw-card-image-wrapper">
    {% assign is_trending = false %}
    {% for tag in product.tags %}
      {% if tag == 'Trending' or tag == 'trending' %}
        {% assign is_trending = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    {% if is_trending %}
      <div class="pw-badge-trending">Trending</div>
    {% endif %}

    <a href="{{ product.url }}" class="pw-img-link">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '500x500' }}" alt="{{ product.title | escape }}" class="pw-card-image" loading="lazy">
      {% else %}
        <div class="pw-card-placeholder"></div>
      {% endif %}
    </a>

    <!-- ADD button overlapping bottom-right of image -->
    <form method="post" action="/cart/add" class="pw-add-form">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="pw-add-btn" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}ADD{% else %}SOLD{% endif %}
      </button>
    </form>
  </div>

  <!-- Info Section -->
  <div class="pw-card-info">
    <a href="{{ product.url }}" class="pw-card-title-link">
      <h3 class="pw-card-title">{{ product.title }}</h3>
    </a>

    {% assign show_edition = false %}
    {% for tag in product.tags %}
      {% assign lt = tag | downcase %}
      {% if lt contains 'edition' or lt contains '2026' or lt contains '2025' or lt contains '2024' %}
        <div class="pw-card-tag">{{ tag | capitalize }}</div>
        {% assign show_edition = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    {% if show_edition == false %}
      <div class="pw-card-tag">Latest Edition</div>
    {% endif %}

    <div class="pw-price-row">
      <span class="pw-current-price">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
        <span class="pw-discount">({{ discount }}% OFF)</span>
      {% endif %}
    </div>
    {% if product.compare_at_price > product.price %}
      <div class="pw-original-price">{{ product.compare_at_price | money }}</div>
    {% endif %}
  </div>
</div>

<style>
  .pw-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 10px;
    border: 1px solid #e0e0e0;
    overflow: visible; /* allow ADD btn to overlap */
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    position: relative;
  }

  .pw-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    transform: translateY(-1px);
  }

  /* Trending badge */
  .pw-badge-trending {
    position: absolute;
    top: 8px;
    left: 0;
    background: #16a34a;
    color: white;
    padding: 3px 9px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 0 4px 4px 0;
    z-index: 10;
  }

  /* Image area — white bg, fills card top */
  .pw-card-image-wrapper {
    position: relative;
    background: #ffffff;
    border-radius: 10px 10px 0 0;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .pw-img-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .pw-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
    display: block;
  }

  .pw-card:hover .pw-card-image {
    transform: scale(1.03);
  }

  .pw-card-placeholder {
    width: 100%;
    height: 100%;
    background: #f3f4f6;
  }

  /* ADD button — bottom-right, overlapping image/info boundary */
  .pw-add-form {
    position: absolute;
    bottom: -1px;
    right: 10px;
    z-index: 20;
  }

  .pw-add-btn {
    background: #ede9fe;
    color: #5b4df3;
    border: 1.5px solid #a5b4fc;
    border-radius: 8px;
    padding: 8px 20px;
    font-size: 16px;
    font-weight: 800;
    cursor: pointer;
    letter-spacing: 1px;
    font-family: inherit;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(91,77,243,0.12);
  }

  .pw-add-btn:hover:not([disabled]) {
    background: #5b4df3;
    color: white;
    border-color: #5b4df3;
  }

  .pw-add-btn[disabled] {
    background: #f3f4f6;
    color: #9ca3af;
    border-color: #e5e7eb;
    cursor: not-allowed;
    font-size: 13px;
    letter-spacing: 0;
  }

  /* Info section */
  .pw-card-info {
    padding: 10px 10px 12px;
    border-top: 1px solid #f0f0f0;
  }

  .pw-card-title-link { text-decoration: none; color: inherit; }

  .pw-card-title {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    margin: 0 0 6px 0;
    color: #1a1a1a;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pw-card-tag {
    display: inline-block;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 5px;
    margin-bottom: 6px;
  }

  .pw-price-row {
    display: flex;
    align-items: baseline;
    gap: 5px;
    margin-bottom: 2px;
    margin-top: 4px;
  }

  .pw-current-price {
    font-size: 17px;
    font-weight: 800;
    color: #111;
  }

  .pw-discount {
    font-size: 12px;
    font-weight: 700;
    color: #16a34a;
  }

  .pw-original-price {
    font-size: 12px;
    color: #9ca3af;
    text-decoration: line-through;
    font-weight: 400;
  }
</style>
