<div class="card-v4">
  <a href="{{ product.url }}" class="card-v4-image-link">
    <div class="card-v4-image-box">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '600x600' }}" alt="{{ product.title | escape }}" class="card-v4-image" loading="lazy">
      {% else %}
        <div class="card-v4-placeholder"></div>
      {% endif %}
      
      {% if product.compare_at_price > product.price %}
        {% assign savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
        <span class="card-v4-badge">{{ savings }}% OFF</span>
      {% endif %}
    </div>
  </a>
  
  <div class="card-v4-content">
    {% if product.vendor %}
      <p class="card-v4-vendor">{{ product.vendor }}</p>
    {% endif %}
    <a href="{{ product.url }}" class="card-v4-title-link">
      <h3 class="card-v4-title">{{ product.title }}</h3>
    </a>
    <div class="card-v4-price-group">
      <span class="card-v4-price">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="card-v4-compare-price">{{ product.compare_at_price | money }}</span>
      {% endif %}
    </div>
    
    <form method="post" action="/cart/add" class="card-v4-form">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="card-v4-btn" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}
          Add to Bag
        {% else %}
          Out of Stock
        {% endif %}
      </button>
    </form>
  </div>
</div>

<style>
  .card-v4 {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #eaedf0;
    overflow: hidden;
    padding: 16px;
    transition: all 0.2s ease-in-out;
  }

  .card-v4:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); /* Soft lift shadow */
    border-color: #d1d5db;
    transform: translateY(-2px); /* Slight lift */
  }

  .card-v4-image-link {
    display: block;
    position: relative;
    margin-bottom: 20px;
  }

  .card-v4-image-box {
    position: relative;
    width: 100%;
    aspect-ratio: 1; /* Keep it square so tall books fit perfectly */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-v4-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain; /* Prevents Cropping! */
    transition: transform 0.4s ease;
  }

  .card-v4:hover .card-v4-image {
    transform: scale(1.03);
  }

  .card-v4-placeholder {
    width: 100%;
    height: 100%;
    background: #f8fafc;
    border-radius: 8px;
  }

  .card-v4-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #17c964; /* Exact modern green */
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0px;
    z-index: 2;
  }

  .card-v4-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-v4-vendor {
    font-size: 13px;
    color: #868e96;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
    margin: 0 0 8px 0;
  }

  .card-v4-title-link {
    text-decoration: none;
    color: #212529;
  }

  .card-v4-title {
    font-size: 18px; 
    font-weight: 800;
    line-height: 1.4;
    margin: 0 0 16px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: #212529;
    transition: color 0.15s;
  }

  .card-v4-title-link:hover .card-v4-title {
    color: var(--brand-purple, #5b4df3);
  }

  .card-v4-price-group {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 24px;
  }

  .card-v4-price {
    font-size: 22px;
    font-weight: 800;
    color: #000;
    letter-spacing: -0.5px;
  }

  .card-v4-compare-price {
    font-size: 16px;
    color: #adb5bd;
    text-decoration: line-through;
    font-weight: 600;
  }

  .card-v4-form {
    margin-top: auto;
  }

  .card-v4-btn {
    width: 100%;
    padding: 14px;
    background: #0f172a; 
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .card-v4-btn:hover:not([disabled]) {
    background: #1e293b; 
    transform: scale(0.98); 
  }

  .card-v4-btn[disabled] {
    background: #f4f5f7;
    color: #adb5bd;
    cursor: not-allowed;
    border: none;
  }
</style>
