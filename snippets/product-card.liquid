<div class="pw-card">
  <div class="pw-card-image-wrapper">
    {% assign is_trending = false %}
    {% for tag in product.tags %}
      {% if tag == 'Trending' or tag == 'trending' %}
        {% assign is_trending = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    
    {% if is_trending %}
      <div class="pw-trending-ribbon">Trending</div>
    {% endif %}

    <a href="{{ product.url }}">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '500x500' }}" alt="{{ product.title | escape }}" class="pw-card-image" loading="lazy">
      {% else %}
        <div class="pw-card-placeholder"></div>
      {% endif %}
    </a>
    <form method="post" action="/cart/add" class="pw-add-form">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="pw-add-btn" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}ADD{% else %}OUT{% endif %}
      </button>
    </form>
  </div>
  
  <div class="pw-card-info">
    <a href="{{ product.url }}" class="pw-card-title-link">
      <h3 class="pw-card-title">{{ product.title }}</h3>
    </a>
    
    {% assign show_edition = false %}
    {% for tag in product.tags %}
      {% assign lowercase_tag = tag | downcase %}
      {% if lowercase_tag contains 'edition' or lowercase_tag contains '2026' or lowercase_tag contains '2025' or lowercase_tag contains '2024' %}
        <div class="pw-card-tag">{{ tag | capitalize }}</div>
        {% assign show_edition = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    
    {% if show_edition == false %}
      <div class="pw-card-tag">Latest Edition</div>
    {% endif %}

    <div class="pw-price-row">
      <div class="pw-price-left">
        <span class="pw-current-price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
          <span class="pw-discount">({{ discount }}% OFF)</span>
        {% endif %}
      </div>
      
      <!-- PW Style Rating Badge -->
      <div class="pw-rating-badge">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" style="margin-right:2px"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"></path></svg>
        4.8
      </div>
    </div>
    {% if product.compare_at_price > product.price %}
      <div class="pw-original-price">{{ product.compare_at_price | money }}</div>
    {% endif %}
  </div>
</div>

<style>
  .pw-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    transition: all 0.2s ease-in-out;
    position: relative;
  }

  .pw-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .pw-trending-ribbon {
    position: absolute;
    top: 0;
    left: -8px;
    background: #16a34a; /* Vibrant PW green */
    color: white;
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 10;
    border-radius: 0 4px 4px 0;
    box-shadow: 2px 2px 4px rgba(0,0,0,0.1);
  }

  /* Ribbon fold effect */
  .pw-trending-ribbon::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    border-width: 8px 8px 0 0;
    border-style: solid;
    border-color: #14532d transparent transparent transparent; /* Darker green shade */
  }

  .pw-card-image-wrapper {
    position: relative;
    padding: 20px;
    background: #fff;
    border-radius: 12px 12px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
  }

  .pw-card-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .pw-card:hover .pw-card-image {
    transform: scale(1.03);
  }

  .pw-card-placeholder {
    width: 100%;
    height: 100%;
    background: #f3f4f6;
    border-radius: 8px;
  }

  .pw-add-form {
    position: absolute;
    bottom: -15px; /* Overlap the border between image and text */
    right: 20px;
    z-index: 10;
  }

  .pw-add-btn {
    background: #f8f6ff; /* Very pale purple matching the mockup */
    color: var(--brand-purple, #5b4df3);
    border: 1px solid var(--brand-purple, #5b4df3);
    border-radius: 8px;
    padding: 10px 22px;
    font-size: 18px;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    transition: all 0.2s ease;
  }

  .pw-add-btn:hover:not([disabled]) {
    background: var(--brand-purple, #5b4df3);
    color: white;
    transform: scale(1.02);
  }

  .pw-add-btn[disabled] {
    background: #f3f4f6;
    color: #9ca3af;
    border-color: #d1d5db;
    cursor: not-allowed;
    font-size: 14px;
    padding: 8px 12px;
  }

  .pw-card-info {
    padding: 24px 20px 20px 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .pw-card-title-link {
    text-decoration: none;
    color: #111827;
  }

  .pw-card-title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 12px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 46px;
    color: #111827;
    transition: color 0.2s;
  }

  .pw-card-title-link:hover .pw-card-title {
    color: var(--brand-purple, #5b4df3);
  }

  .pw-card-tag {
    background: #e0f2fe; /* Light blue */
    color: #0284c7; /* Darker blue */
    display: inline-block;
    padding: 5px 12px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 16px;
    align-self: flex-start;
  }

  .pw-price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
  }

  .pw-price-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pw-rating-badge {
    display: flex;
    align-items: center;
    background: #16a34a; /* Matches PW green */
    color: white;
    padding: 3px 6px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 800;
  }

  .pw-current-price {
    font-size: 22px;
    font-weight: 800;
    color: #111827;
    letter-spacing: -0.5px;
  }

  .pw-discount {
    font-size: 16px;
    font-weight: 700;
    color: #16a34a; /* Vibrant green */
  }

  .pw-original-price {
    font-size: 16px;
    color: #9ca3af;
    text-decoration: line-through;
    font-weight: 500;
  }
</style>
