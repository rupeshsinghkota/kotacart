<div class="card-v3">
  <a href="{{ product.url }}" class="card-v3-image-link">
    <div class="card-v3-image-box">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '500x500', crop: 'center' }}" alt="{{ product.title | escape }}" class="card-v3-image" loading="lazy">
      {% else %}
        <div class="card-v3-placeholder"></div>
      {% endif %}
      
      {% if product.compare_at_price > product.price %}
        {% assign savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
        <span class="card-v3-badge">{{ savings }}% OFF</span>
      {% endif %}
    </div>
  </a>
  
  <div class="card-v3-content">
    {% if product.vendor %}
      <p class="card-v3-vendor">{{ product.vendor }}</p>
    {% endif %}
    <a href="{{ product.url }}" class="card-v3-title-link">
      <h3 class="card-v3-title">{{ product.title }}</h3>
    </a>
    <div class="card-v3-price-group">
      <span class="card-v3-price">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="card-v3-compare-price">{{ product.compare_at_price | money }}</span>
      {% endif %}
    </div>
    
    <form method="post" action="/cart/add" class="card-v3-form">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="card-v3-btn" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}
          Add to Bag
        {% else %}
          Out of Stock
        {% endif %}
      </button>
    </form>
  </div>
</div>

<style>
  .card-v3 {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    overflow: hidden;
    transition: all 0.2s ease-in-out;
  }

  .card-v3:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08); /* Soft lift shadow */
    border-color: #cbd5e1;
    transform: translateY(-4px); /* Slight lift */
  }

  .card-v3-image-link {
    display: block;
    position: relative;
    padding: 12px 12px 0 12px; /* Pad inside the card so image has a border around it like the mockup */
  }

  .card-v3-image-box {
    position: relative;
    border-radius: 8px; /* Inner rounded corners for the image box */
    overflow: hidden;
    background: #f8fafc;
    aspect-ratio: 4 / 3; /* More horizontal layout instead of 1:1 boxy */
  }

  .card-v3-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card-v3:hover .card-v3-image {
    transform: scale(1.05);
  }

  .card-v3-placeholder {
    width: 100%;
    height: 100%;
    background: #f1f5f9;
  }

  .card-v3-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: #22c55e; /* Exact modern green */
    color: white;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    z-index: 2;
  }

  .card-v3-content {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-v3-vendor {
    font-size: 11px;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
    margin: 0 0 6px 0;
  }

  .card-v3-title-link {
    text-decoration: none;
    color: #0f172a;
  }

  .card-v3-title {
    font-size: 15px; /* Perfect size, not too big */
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 12px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 42px; /* Set height to prevent layout shifts */
    transition: color 0.15s;
  }

  .card-v3-title-link:hover .card-v3-title {
    color: var(--brand-purple, #5b4df3);
  }

  .card-v3-price-group {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 20px;
  }

  .card-v3-price {
    font-size: 18px;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.5px;
  }

  .card-v3-compare-price {
    font-size: 13px;
    color: #94a3b8;
    text-decoration: line-through;
    font-weight: 500;
  }

  .card-v3-form {
    margin-top: auto;
  }

  .card-v3-btn {
    width: 100%;
    padding: 12px;
    background: #0f172a; /* Dark premium navy/black */
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.1s ease;
  }

  .card-v3-btn:hover:not([disabled]) {
    background: #1e293b; /* Slightly lighter on hover */
    transform: scale(0.98); /* Satisfying tiny click shrink */
  }

  .card-v3-btn[disabled] {
    background: #f1f5f9;
    color: #94a3b8;
    cursor: not-allowed;
    border: 1px solid #e2e8f0;
  }
</style>
