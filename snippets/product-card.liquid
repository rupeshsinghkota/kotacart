<div class="pw-card">
  <div class="pw-card-image-wrapper">
    {% assign is_trending = false %}
    {% for tag in product.tags %}
      {% if tag == 'Trending' or tag == 'trending' %}
        {% assign is_trending = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    
    {% if is_trending %}
      <div class="pw-badge-trending">Trending</div>
    {% endif %}

    <a href="{{ product.url }}" class="pw-card-img-link">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '500x500' }}" alt="{{ product.title | escape }}" class="pw-card-image" loading="lazy">
      {% else %}
        <div class="pw-card-placeholder"></div>
      {% endif %}
    </a>
  </div>
  
  <div class="pw-card-info">
    <a href="{{ product.url }}" class="pw-card-title-link">
      <h3 class="pw-card-title">{{ product.title }}</h3>
    </a>
    
    <div class="pw-card-meta">
      {% assign show_edition = false %}
      {% for tag in product.tags %}
        {% assign lowercase_tag = tag | downcase %}
        {% if lowercase_tag contains 'edition' or lowercase_tag contains '2026' or lowercase_tag contains '2025' or lowercase_tag contains '2024' %}
          <span class="pw-card-tag">{{ tag | capitalize }}</span>
          {% assign show_edition = true %}
          {% break %}
        {% endif %}
      {% endfor %}
      {% if show_edition == false %}
        <span class="pw-card-tag">Latest Edition</span>
      {% endif %}
      <div class="pw-rating-badge">
        <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"></path></svg>
        4.8
      </div>
    </div>

    <div class="pw-price-block">
      <span class="pw-current-price">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="pw-original-price">{{ product.compare_at_price | money }}</span>
        {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
        <span class="pw-discount">{{ discount }}% OFF</span>
      {% endif %}
    </div>

    <form method="post" action="/cart/add" class="pw-add-form">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="pw-add-btn" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4H6z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          Add to Bag
        {% else %}
          Out of Stock
        {% endif %}
      </button>
    </form>
  </div>
</div>

<style>
  .pw-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 10px;
    border: 1px solid #e8eaed;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    position: relative;
    height: 100%;
  }

  .pw-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  /* Trending ribbon */
  .pw-badge-trending {
    position: absolute;
    top: 8px;
    left: 0;
    background: #16a34a;
    color: white;
    padding: 3px 10px 3px 8px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: 0 4px 4px 0;
    z-index: 10;
  }

  /* Image area */
  .pw-card-image-wrapper {
    position: relative;
    background: #f8f9fa;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .pw-card-img-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 12px;
  }

  .pw-card-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.35s ease;
  }

  .pw-card:hover .pw-card-image {
    transform: scale(1.04);
  }

  .pw-card-placeholder {
    width: 100%;
    height: 140px;
    background: #f3f4f6;
  }

  /* Info section */
  .pw-card-info {
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex-grow: 1;
  }

  .pw-card-title-link { text-decoration: none; color: inherit; }

  .pw-card-title {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
    color: #1a1a1a;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 36px;
    transition: color 0.2s;
  }

  .pw-card-title-link:hover .pw-card-title { color: #5b4df3; }

  /* Tag + rating inline */
  .pw-card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .pw-card-tag {
    background: #eef3ff;
    color: #3b5bdb;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .pw-rating-badge {
    display: flex;
    align-items: center;
    gap: 2px;
    background: #16a34a;
    color: white;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    margin-left: auto;
  }

  /* Price block */
  .pw-price-block {
    display: flex;
    align-items: baseline;
    gap: 5px;
    flex-wrap: wrap;
  }

  .pw-current-price {
    font-size: 16px;
    font-weight: 800;
    color: #111;
    letter-spacing: -0.3px;
  }

  .pw-original-price {
    font-size: 12px;
    color: #9ca3af;
    text-decoration: line-through;
    font-weight: 400;
  }

  .pw-discount {
    font-size: 11px;
    font-weight: 700;
    color: #16a34a;
  }

  /* Add to Bag button — inside info, full width */
  .pw-add-form { margin-top: auto; }

  .pw-add-btn {
    width: 100%;
    background: #f0eeff;
    color: #5b4df3;
    border: 1px solid #c7c0ff;
    border-radius: 7px;
    padding: 7px 10px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .pw-add-btn:hover:not([disabled]) {
    background: #5b4df3;
    color: white;
    border-color: #5b4df3;
  }

  .pw-add-btn[disabled] {
    background: #f3f4f6;
    color: #9ca3af;
    border-color: #e5e7eb;
    cursor: not-allowed;
  }
</style>
