<div class="container cart-page">
  <h1 class="section-title">Your Learning Basket</h1>

  {% if cart.item_count > 0 %}
    <form action="/cart" method="post" novalidate>
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item-image">
              <img src="{{ item | img_url: '150x150' }}" alt="{{ item.title }}">
            </div>
            <div class="cart-item-details">
              <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
              {% unless item.product.has_only_default_variant %}
                <p class="variant-info">{{ item.variant.title }}</p>
              {% endunless %}
              <p class="cart-item-price">{{ item.price | money }}</p>
            </div>
            <div class="cart-item-quantity">
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
            </div>
            <div class="cart-item-total">
              {{ item.line_price | money }}
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="cart-footer">
        <div class="cart-summary">
          <p>Subtotal: <strong>{{ cart.total_price | money }}</strong></p>
          <p class="tax-shipping-info">Shipping and taxes calculated at checkout</p>
          <button type="submit" name="checkout" class="btn-gold btn-checkout">Proceed to Checkout</button>
        </div>
      </div>
    </form>
  {% else %}
    <div class="empty-cart">
      <p>Your basket is currently empty.</p>
      <a href="/collections/all" class="btn-gold">Start Shopping</a>
    </div>
  {% endif %}
</div>

<style>
  .cart-page { padding: 60px 0; }
  .cart-item { display: grid; grid-template-columns: 100px 1fr 100px 100px; gap: 20px; align-items: center; padding: 20px 0; border-bottom: 1px solid #EEE; }
  .cart-item img { border-radius: 8px; width: 100%; border: 1px solid #EEE; }
  .cart-item h3 { font-size: 18px; margin: 0; }
  .cart-item h3 a { text-decoration: none; color: var(--color-primary); }
  .variant-info { font-size: 14px; color: #666; margin: 4px 0; }
  .cart-item-quantity input { width: 50px; padding: 5px; border-radius: 4px; border: 1px solid #ddd; }
  
  .cart-footer { margin-top: 40px; display: flex; justify-content: flex-end; }
  .cart-summary { text-align: right; background: #F8F9FA; padding: 30px; border-radius: 12px; border: 1px solid #EEE; min-width: 350px; }
  .cart-summary p { font-size: 20px; margin-bottom: 10px; }
  .tax-shipping-info { font-size: 14px; color: #999; margin-bottom: 20px; }
  .btn-checkout { width: 100%; font-size: 18px; }
  
  .empty-cart { text-align: center; padding: 100px 0; }
  
  @media (max-width: 768px) {
    .cart-item { grid-template-columns: 1fr 1fr; }
    .cart-item-quantity, .cart-item-total { text-align: right; }
  }
</style>
