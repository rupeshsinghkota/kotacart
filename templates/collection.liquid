<div class="container collection-header">
  <h1 class="col-page-title">{{ collection.title }}</h1>
  {% if collection.description != blank %}
    <div class="col-page-desc">{{ collection.description }}</div>
  {% endif %}
</div>

<div class="container">
  <div class="col-products-grid">
    {% for product in collection.products %}
      <div class="col-product-item">
        {% render 'product-card', product: product %}
      </div>
    {% else %}
      <p style="grid-column: 1/-1; text-align:center; padding:60px 0; color:#999;">No products found in this collection.</p>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="pagination">{{ paginate | default_pagination }}</div>
  {% endif %}
</div>

<style>
  .collection-header {
    padding: 24px 0 16px;
  }
  .col-page-title {
    font-size: 22px;
    font-weight: 800;
    color: #111;
    margin: 0 0 6px;
  }
  .col-page-desc {
    font-size: 14px;
    color: #666;
    margin: 0;
  }

  /* Desktop: 4-column grid */
  .col-products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 60px;
  }

  @media (max-width: 1100px) {
    .col-products-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .collection-header { padding: 14px 0 10px; }
    .col-page-title { font-size: 18px; }

    /* 2-column grid — same as home page, same as PW Store */
    .col-products-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 80px; /* space for sticky bar */
    }
  }

  .pagination {
    text-align: center;
    padding: 30px 0;
  }
</style>
