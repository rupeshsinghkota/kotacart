  .price-container-v3 { margin-bottom: 25px; }
  .price-row { display: flex; align-items: baseline; gap: 10px; margin-bottom: 5px; }
  .current-price { font-size: 24px; font-weight: 800; color: var(--pw-text-dark); }
  .old-price { font-size: 14px; text-decoration: line-through; color: var(--pw-text-gray); }
  .discount-percent-v3 { color: #16a34a; font-weight: 700; font-size: 15px; }
  .stock-status-v3 { color: #16a34a; font-weight: 700; font-size: 14px; margin-top: 5px; }

  /* Offers */
  .offers-section-v3 {
    background: #fef9c3; /* Soft PW Yellow/Cream */
    padding: 16px;
    border-radius: 12px;
    border: 1px solid #fde047;
    margin-bottom: 30px;
  }
  .offer-card { display: flex; gap: 15px; align-items: flex-start; }
  .offer-icon { font-size: 20px; }
  .offer-details strong { display: block; font-size: 14px; margin-bottom: 2px; }
  .offer-details p { font-size: 12px; margin: 0; color: #555; }
  .offer-details span { font-weight: 800; color: #f59e0b; }

  /* Pincode */
  .pincode-checker-v3 {
    border: 1px solid var(--pw-border);
    border-radius: 12px;
    padding: 15px;
    margin-bottom: 30px;
  }
  .pincode-header {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .pincode-input-wrapper {
    display: flex;
    border: 1px solid var(--pw-border);
    border-radius: 6px;
    overflow: hidden;
  }
  .pincode-input-wrapper input {
    flex-grow: 1;
    border: none;
    padding: 12px 15px;
    font-size: 14px;
    outline: none;
  }
  .pincode-input-wrapper button {
    background: none;
    border: none;
    padding: 0 20px;
    color: var(--pw-purple);
    font-weight: 800;
    cursor: pointer;
  }

  /* Features */
  .product-features-v3 {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-bottom: 35px;
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: #444;
  }

  /* Description Box Styling */
  .product-description-box {
    border: 1px solid var(--pw-border);
    border-radius: 12px;
    overflow: hidden;
    margin: 60px 0 30px 0;
    background: white;
  }

  .description-header {
    display: flex;
    background: #f8f9fa;
    border-bottom: 1px solid var(--pw-border);
  }

  .description-header .desc-tab {
    padding: 15px 25px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    color: var(--pw-text-gray);
    transition: all 0.2s;
    border-bottom: 2px solid transparent;
    margin-bottom: 0;
  }

  .description-header .desc-tab.active {
    color: var(--pw-purple);
    border-bottom-color: var(--pw-purple);
    background: white;
  }

  .description-body {
    padding: 40px;
    font-size: 16px;
    line-height: 1.8;
    color: #374151;
  }

  /* Handle raw text with newlines */
  .tab-pane {
    white-space: pre-wrap;
    word-break: break-word;
  }

  @media (max-width: 768px) {
    .description-body {
      padding: 20px;
      max-height: 400px;
      overflow-y: auto;
      font-size: 14px;
    }
  }

  /* Custom Scrollbar */
  .description-body::-webkit-scrollbar {
    width: 6px;
  }
  .description-body::-webkit-scrollbar-track {
    background: #f1f1f1;
  }
  .description-body::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }

  .tab-pane {
    display: none;
  }
  .tab-pane.active {
    display: block;
  }

  .features-list-v3 {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .features-list-v3 li {
    padding: 10px 0;
    border-bottom: 1px solid #f1f1f1;
    font-weight: 500;
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    .thumbnail-strip, .desktop-actions-v3 { display: none !important; }
    
    .product-main-grid { grid-template-columns: 1fr; gap: 10px; }
    
    .product-v3-wrapper { padding-top: 0; }
    
    .breadcrumb-v3 {
      background: white;
      padding: 6px 15px;
      margin-bottom: 0;
      border-bottom: 1px solid #f8f8f8;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      font-weight: 600;
      color: #111;
    }
    
    .breadcrumb-left svg { width: 14px; height: 14px; color: #111; }
    .breadcrumb-left span, .breadcrumb-left a { font-weight: 600; color: #111; font-size: 13px; }
    
    .main-image-wrapper {
      border: none;
      border-radius: 0;
      margin: 0 -20px;
      width: auto;
      max-width: none;
      max-height: 38vh;
      margin-bottom: 10px;
    }
    .mobile-gallery-img { max-height: 38vh; object-fit: contain; }
    .product-title-v3 { font-size: 18px; line-height: 1.25; margin-bottom: 2px; }
    .product-vendor-v3 { font-size: 12px; margin-bottom: 6px; color: #666; }
    .price-container-v3 { margin-bottom: 12px; }
    .product-description-box { margin-top: 15px; }
    .current-price { font-size: 21px; font-weight: 800; line-height: 1; }
    .old-price { font-size: 13px; }
    .discount-percent-v3 { font-size: 13px; }
    .stock-status-v3 { font-size: 12px; margin-top: -2px; }

    .mobile-sticky-actions-v3 {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      background: #FFFFFF;
      padding: 12px 16px;
      padding-bottom: calc(12px + env(safe-area-inset-bottom));
      box-shadow: 0 -10px 20px rgba(0,0,0,0.04);
      border-top: 1px solid #f1f1f1;
      z-index: 2000;
      box-sizing: border-box;
      display: flex;
      justify-content: center;
    }
    .mobile-btn-group {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      width: 100%;
    }
    .m-btn-primary {
      background: #5b4df3;
      color: white;
      border: none;
      border-radius: 10px;
      font-weight: 700;
      padding: 14px;
      font-size: 16px;
      width: 100%;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(91, 77, 243, 0.1);
    }
    .m-btn-secondary {
      background: white;
      color: #5b4df3;
      border: 1.5px solid #5b4df3;
      border-radius: 10px;
      font-weight: 700;
      padding: 14px;
      font-size: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      cursor: pointer;
    }
    
    body { padding-bottom: 100px; } /* Space for sticky bar */
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const scrollContainer = document.querySelector('.mobile-scroll-container');
    const slides = document.querySelectorAll('.mobile-slide');
    const dots = document.querySelectorAll('.dot');
    const thumbs = document.querySelectorAll('.thumb-item');

    // Desktop Thumbnail Clicks
    thumbs.forEach((thumb, index) => {
      thumb.addEventListener('click', function() {
        // Find corresponding slide and scroll to it
        slides[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        
        thumbs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        
        // Also update dots for mobile visibility if switched on desktop
        updateDots(index);
      });
    });

    // Mobile Scroll Dots Update
    function updateDots(index) {
      dots.forEach(dot => dot.classList.remove('active'));
      if (dots[index]) dots[index].classList.add('active');
    }

    if (scrollContainer && dots.length > 0) {
      scrollContainer.addEventListener('scroll', () => {
        const slideWidth = scrollContainer.offsetWidth;
        const index = Math.round(scrollContainer.scrollLeft / slideWidth);
        updateDots(index);
        
        // Keep desktop thumbnails in sync
        thumbs.forEach(t => t.classList.remove('active'));
        if (thumbs[index]) thumbs[index].classList.add('active');
      });
    }

    // Variant selection logic
    const pills = document.querySelectorAll('.variant-pills .pill');
    const variantInputs = document.querySelectorAll('input[name="id"]');
    
    pills.forEach(pill => {
      pill.addEventListener('click', function() {
        const variantId = this.getAttribute('data-variant-id');
        
        // Update UI
        pills.forEach(p => p.classList.remove('active'));
        this.classList.add('active');
        
        // Update all forms (Desktop and Mobile)
        variantInputs.forEach(input => {
          input.value = variantId;
        });
      });
    });

    // Description Tab Logic
    const descTabs = document.querySelectorAll('.description-header .desc-tab');
    const tabPanes = document.querySelectorAll('.tab-pane');

    descTabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const target = this.getAttribute('data-tab');
        
        // Update Tabs
        descTabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        
        // Update Panes
        tabPanes.forEach(pane => {
          pane.classList.remove('active');
          if (pane.id === 'tab-' + target) {
            pane.classList.add('active');
          }
        });
      });
    });
  });
</script>
