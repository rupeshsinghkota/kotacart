<div class="product-v3-wrapper">
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  
  <div class="container">
    <nav class="breadcrumb-v3">
      <div class="breadcrumb-left">
        <a href="/"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></a> 
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
        <a href="/collections/all">Study Materials</a>
      </div>
      <button class="share-btn mobile-only">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
        Share
      </button>
    </nav>

    <div class="product-main-grid">
      <!-- Left Column: Gallery -->
      <div class="product-gallery-column">
        <div class="gallery-container-v3">
          <div class="thumbnail-strip desktop-only">
            {% for image in product.images %}
              <div class="thumb-item {% if forloop.first %}active{% endif %}" data-image-url="{{ image | img_url: '800x800' }}">
                <img src="{{ image | img_url: '100x100', crop: 'center' }}" alt="{{ product.title }}">
              </div>
            {% endfor %}
          </div>
          
          <div class="main-image-wrapper">
            <div class="mobile-scroll-container">
              {% for image in product.images %}
                <div class="mobile-slide">
                  <img class="mobile-gallery-img" src="{{ image | img_url: '800x800' }}" alt="{{ product.title }}">
                </div>
              {% endfor %}
            </div>
            
            <button class="preview-btn">
              <span>Preview Book</span>
              <img src="https://cdn-icons-png.flaticon.com/512/337/337946.png" alt="PDF" width="16" height="16">
            </button>

            <!-- Scroll Indicators for Mobile -->
            <div class="mobile-dots-v3 mobile-only">
              {% for image in product.images %}
                <span class="dot {% if forloop.first %}active{% endif %}"></span>
              {% endfor %}
            </div>
          </div>
        </div>

        <!-- Desktop Action Buttons (PW Style: Below Image) -->
        <div class="desktop-actions-v3 desktop-only">
          {% form 'product', product, id: 'DesktopProductForm' %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <div class="action-btn-group">
              <button type="submit" name="add" class="btn-secondary-v3">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Add To Bag
              </button>
              <button type="submit" name="checkout" class="btn-primary-v3">Buy Now</button>
            </div>
          {% endform %}
        </div>
      </div>

      <!-- Right Column: Info -->
      <div class="product-info-column">
        <h1 class="product-title-v3">{{ product.title }}</h1>
        <p class="product-vendor-v3">By {{ product.vendor }}</p>

        <div class="price-container-v3">
          <div class="price-row">
            <span class="current-price">{{ product.price | money }}</span>
            {% if current_variant.compare_at_price > product.price %}
              <span class="old-price">{{ current_variant.compare_at_price | money }}</span>
              <span class="discount-percent-v3">
                ({{ current_variant.compare_at_price | minus: product.price | times: 100 | divided_by: current_variant.compare_at_price }}% OFF)
              </span>
            {% endif %}
          </div>
          {% if product.available %}
            <div class="stock-status-v3">In Stock</div>
          {% endif %}
        </div>

        <!-- Offers Section -->
        <div class="offers-section-v3">
          <div class="offer-card">
            <div class="offer-icon">🏷️</div>
            <div class="offer-details">
              <strong>Extra 5% OFF on Prepaid</strong>
              <p>Use code: <span>PREPAID5</span></p>
            </div>
          </div>
        </div>

        <!-- Variants (Language/Edition) -->
        {% if product.variants.size > 1 %}
          <div class="variants-selector-v3">
            <label>Select Variant</label>
            <div class="variant-pills">
              {% for variant in product.variants %}
                <button class="pill {% if variant == current_variant %}active{% endif %}" data-variant-id="{{ variant.id }}">
                  {{ variant.title }}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        <!-- Pincode Checker -->
        <div class="pincode-checker-v3">
          <div class="pincode-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            Check Delivery Options
          </div>
          <div class="pincode-input-wrapper">
            <input type="text" placeholder="Enter Pincode" maxlength="6">
            <button>Check</button>
          </div>
        </div>

        <!-- Product Features List -->
        <div class="product-features-v3">
          <div class="feature-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#28A745" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Verified Study Material</span>
          </div>
          <div class="feature-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#28A745" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Fast Express Delivery</span>
          </div>
          <div class="feature-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#28A745" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>7-Day Replacement Policy</span>
          </div>
        </div>
      </div>
    </div> <!-- Close product-main-grid -->

    <!-- Description Box (Full Width below grid on Desktop) -->
    <div class="product-description-box">
      <div class="description-header">
        <div class="desc-tab active" data-tab="description">Book Description</div>
        <div class="desc-tab" data-tab="features">Key Features</div>
      </div>
      <div class="description-body">
        <div id="tab-description" class="tab-pane active">
          {{ product.description | replace: '\n', '<br>' }}
        </div>
        <div id="tab-features" class="tab-pane">
          <ul class="features-list-v3">
            <li>📚 Comprehensive Complete Set</li>
            <li>✅ 100% Verified Content</li>
            <li>🚚 Fast Express Shipping</li>
            <li>🔄 7-Day Easy Replacement</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Sticky Footer Action Bar -->
  <div class="mobile-sticky-actions-v3 mobile-only">
    {% form 'product', product, class: 'mobile-action-form' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <div class="mobile-btn-group">
        <button type="submit" name="add" class="m-btn-secondary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Add To Bag
        </button>
        <button type="submit" name="checkout" class="m-btn-primary">Buy Now</button>
      </div>
    {% endform %}
  </div>
</div>

<style>
  /* Utility Classes */
  @media (min-width: 769px) {
    .mobile-only { display: none !important; }
  }
  @media (max-width: 768px) {
    .desktop-only { display: none !important; }
  }

  :root {
    --pw-purple: #5b4df3; /* PW Store Primary Purple */
    --pw-green: #16a34a;
    --pw-bg-light: #f9f9fb;
    --pw-border: #e2e8f0;
    --pw-text-dark: #1f2937;
    --pw-text-gray: #6b7280;
  }

  .product-v3-wrapper {
    background: white;
    padding-bottom: 60px;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }
  .product-v3-wrapper .container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Breadcrumb */
  .pm-back-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #000;
    display: flex;
    align-items: center;
    width: 32px;
  }
  .pm-title-container {
    flex: 1;
    text-align: center;
    overflow: hidden;
    padding: 0 10px;
  }
  .pm-title-text {
    font-size: 13px;
    font-weight: 700;
    color: #111;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: inline-block;
    max-width: 100%;
  }
  .pm-search-container {
    width: 32px;
    display: flex;
    justify-content: flex-end;
  }  
  .breadcrumb-v3 {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    font-size: 14px;
    color: var(--pw-text-gray);
  }
  .breadcrumb-left {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .breadcrumb-left a, .breadcrumb-left span {
    color: var(--pw-text-gray);
    text-decoration: none;
    font-weight: 500;
  }
  .breadcrumb-v3 a:first-child svg {
    color: var(--pw-text-gray);
  }

  .share-btn {
    background: none;
    border: none;
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 700;
    font-size: 14px;
    color: #111;
    cursor: pointer;
  }

  /* Grid Layout */
  .product-main-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: start;
  }

  /* Gallery Styling */
  .gallery-container-v3 {
    display: flex;
    gap: 20px;
  }
  .thumbnail-strip {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 80px;
    flex-shrink: 0;
  }
  .thumb-item {
    border: 1px solid var(--pw-border);
    border-radius: 8px;
    cursor: pointer;
    overflow: hidden;
    padding: 2px;
    transition: all 0.2s;
  }
  .thumb-item.active { border-color: var(--pw-purple); box-shadow: 0 0 0 1px var(--pw-purple); }
  .thumb-item img { width: 100%; height: auto; display: block; }
  
  .main-image-wrapper {
    flex-grow: 1;
    position: relative;
    border: 1px solid var(--pw-border);
    border-radius: 12px;
    background: white;
    overflow: hidden;
  }
  
  .mobile-scroll-container {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }
  
  .mobile-scroll-container::-webkit-scrollbar {
    display: none;
  }

  .mobile-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    width: 100%;
  }

  .mobile-gallery-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .mobile-dots-v3 {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #E2E8F0;
    transition: all 0.3s;
  }

  .dot.active {
    background: #333;
    width: 14px;
    border-radius: 4px;
  }
  
  .preview-btn {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: white;
    border: 1px solid var(--pw-border);
    padding: 6px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    cursor: pointer;
    z-index: 20;
  }
  .preview-btn img { margin-top: -1px; }

  /* Action Buttons (Desktop) */
  .desktop-actions-v3 {
    margin: 0 0 30px 0;
  }
  .action-btn-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }
  .btn-primary-v3, .btn-secondary-v3, .m-btn-primary, .m-btn-secondary {
    padding: 18px;
    border-radius: 8px;
    font-weight: 800;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .btn-primary-v3, .m-btn-primary {
    background: var(--pw-purple);
    color: white;
    border: none;
  }
  .btn-secondary-v3, .m-btn-secondary {
    background: white;
    color: var(--pw-purple);
    border: 1.5px solid var(--pw-purple);
  }

  /* Info Section */
  .product-title-v3 {
    font-size: 24px;
    font-weight: 700;
    color: var(--pw-text-dark);
    line-height: 1.4;
    margin: 0 0 5px 0;
  }
  .product-vendor-v3 {
    font-size: 14px;
    color: var(--pw-text-gray);
