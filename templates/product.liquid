<div class="container product-page">
  <div class="product-main">
    <div class="product-gallery">
      {% for image in product.images %}
        <img src="{{ image | img_url: '800x800' }}" alt="{{ product.title }}" class="gallery-image">
      {% endfor %}
    </div>
    
    <div class="product-details">
      <nav class="breadcrumb">
        <a href="/">Home</a> / <a href="/collections/all">Study Material</a>
      </nav>
      
      <h1 class="product-title-large">{{ product.title }}</h1>
      <p class="product-vendor-badge">{{ product.vendor }} Verified</p>
      
      <div class="pricing-large">
        <span class="price-main">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="compare-at-main">{{ product.compare_at_price | money }}</span>
          <span class="save-badge">SAVE {{ product.compare_at_price | minus: product.price | money }}</span>
        {% endif %}
      </div>

      <div class="product-meta-boxes">
        <div class="meta-box">
          <strong>Condition</strong>
          <span>Gently Used / Like New</span>
        </div>
        <div class="meta-box">
          <strong>Shipping</strong>
          <span>Free Express Delivery</span>
        </div>
      </div>

      <div class="add-to-cart-section">
        {% form 'product', product %}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          <button type="submit" class="btn-primary-large">Add to Cart</button>
        {% endform %}
        
        <a href="https://wa.me/911234567890?text=I'm interested in {{ product.title | url_encode }}" class="btn-whatsapp">
           Ask on WhatsApp
        </a>
      </div>

      <div class="product-description">
        <h3>Material Details</h3>
        {{ product.description }}
      </div>
    </div>
  </div>
</div>

<style>
  .product-page { padding: 40px 0; }
  .product-main { display: grid; grid-template-columns: 1.2fr 1fr; gap: 60px; }
  .gallery-image { width: 100%; border-radius: 12px; margin-bottom: 20px; border: 1px solid #EEE; }
  .product-title-large { font-size: 32px; color: var(--color-primary); margin: 10px 0; }
  .product-vendor-badge { display: inline-block; background: #E1F0FF; color: #0070E0; padding: 4px 12px; border-radius: 20px; font-weight: 600; font-size: 13px; }
  .pricing-large { margin: 30px 0; display: flex; align-items: center; gap: 15px; }
  .price-main { font-size: 36px; font-weight: 800; color: var(--color-primary); }
  .compare-at-main { font-size: 20px; text-decoration: line-through; color: #999; }
  .save-badge { background: #27AE60; color: white; padding: 4px 10px; border-radius: 4px; font-weight: 700; }
  
  .product-meta-boxes { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 30px 0; }
  .meta-box { background: #F8F9FA; padding: 15px; border-radius: 8px; border: 1px solid #EEE; }
  .meta-box strong { display: block; font-size: 14px; color: #666; margin-bottom: 5px; }
  
  .btn-primary-large { width: 100%; background: var(--color-primary); color: white; border: none; padding: 18px; border-radius: 8px; font-size: 18px; font-weight: 700; cursor: pointer; margin-bottom: 15px; }
  .btn-whatsapp { width: 100%; display: flex; align-items: center; justify-content: center; background: #25D366; color: white; padding: 15px; border-radius: 8px; text-decoration: none; font-weight: 700; }
  
  @media (max-width: 992px) {
    .product-main { grid-template-columns: 1fr; }
  }
</style>
